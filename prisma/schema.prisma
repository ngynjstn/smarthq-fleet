// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Appliance {
  id        String    @id @default(cuid())
  name      String    // human label, e.g. "Kitchen Fridge"
  type      String    // "REFRIGERATOR" | "WASHER" | "DRYER" | "OVEN" — validated in app via zod
  model     String    // model number, e.g. "PFE28KYNFS"
  createdAt DateTime  @default(now())
  readings  Reading[] // one appliance has many readings
}

model Reading {
  id          String    @id @default(cuid())
  appliance   Appliance @relation(fields: [applianceId], references: [id])
  applianceId String
  metric      String    // "TEMP_C" | "DOOR_OPEN" | "POWER_W" | "CYCLE_STATE"
  value       Float
  recordedAt  DateTime  @default(now())

  @@index([applianceId, recordedAt])
}

// --- Auth.js (NextAuth) models ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("OPS") // "OPS" | "EXEC" — SQLite has no enums, validated in app
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
